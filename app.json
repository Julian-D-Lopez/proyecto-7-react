{
  "expo": {
    "name": "Movilidad Fácil Bogotá",
    "slug": "movilidad-facil-bogota",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "movilidadfacilbogota",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
